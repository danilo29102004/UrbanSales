{% extends "base.html.twig" %}

{% block title %}UrbanSole - Verified Authenticity{% endblock %}

{% block body %}
<style>
    /* HERO SECTION */
    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        padding: 60px 0;
        margin: 40px 0;
    }

    .hero-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .hero-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #00ff00;
        margin-bottom: 20px;
    }

    .hero-title {
        font-size: 56px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    .hero-description {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    .hero-buttons {
        display: flex;
        gap: 20px;
    }

    .btn-shop {
        background: #000;
        color: white;
        padding: 14px 48px;
        border: none;
        border-radius: 0;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
    }

    .btn-shop:hover {
        background: #333;
    }

    .btn-sell {
        background: white;
        color: #000;
        padding: 14px 48px;
        border: 1px solid #000;
        border-radius: 0;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
    }

    .btn-sell:hover {
        background: #000;
        color: white;
    }

    .hero-image {
        background: #1a1a1a;
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        font-size: 120px;
        position: relative;
        overflow: hidden;
    }

    .hero-image::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(0,255,0,0.1), transparent);
    }

    /* SECTION HEADERS */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 60px 0 40px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .see-all {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        text-decoration: none;
        transition: color 0.2s;
    }

    .see-all:hover {
        color: #000;
    }

    /* PRODUCT GRID */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        margin-bottom: 60px;
    }

    .product-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 0;
        overflow: hidden;
        text-decoration: none;
        color: #000;
        transition: all 0.2s;
        position: relative;
    }

    .product-card:hover {
        border-color: #000;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    .product-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #00ff00;
        color: #000;
        padding: 4px 8px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        z-index: 2;
    }

    .product-image {
        background: #f5f5f5;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        position: relative;
    }

    .product-info {
        padding: 16px;
    }

    .product-category {
        font-size: 10px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .product-name {
        font-size: 12px;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 8px;
    }

    .product-price-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .product-price {
        font-size: 14px;
        font-weight: 700;
    }

    .product-change {
        font-size: 11px;
        font-weight: 600;
        color: #00ff00;
    }

    .product-change.down {
        color: #ff4444;
    }

    .product-buy {
        display: none;
        position: absolute;
        bottom: 16px;
        right: 16px;
        background: #000;
        color: white;
        padding: 8px 16px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: none;
        cursor: pointer;
        z-index: 3;
    }

    .product-card:hover .product-buy {
        display: block;
    }

    /* PROMOTIONAL SECTION */
    .promo-section {
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 400"><rect fill="%23000" width="1200" height="400"/></svg>');
        background-size: cover;
        background-position: center;
        color: white;
        padding: 80px 40px;
        text-align: center;
        margin: 80px 0;
        border-radius: 0;
        position: relative;
        overflow: hidden;
    }

    .promo-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.7);
    }

    .promo-content {
        position: relative;
        z-index: 2;
    }

    .promo-subtitle {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #00ff00;
        margin-bottom: 15px;
    }

    .promo-title {
        font-size: 28px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.5px;
        margin-bottom: 10px;
    }

    .promo-description {
        font-size: 14px;
        color: #ccc;
        margin-bottom: 30px;
    }

    .btn-promo {
        background: white;
        color: #000;
        padding: 12px 32px;
        border: none;
        border-radius: 0;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-block;
        text-decoration: none;
    }

    .btn-promo:hover {
        background: #f0f0f0;
    }

    /* PAGINATION */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin: 60px 0;
    }

    .pagination a,
    .pagination span {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e5e5;
        text-decoration: none;
        color: #000;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .pagination a:hover {
        border-color: #000;
    }

    .pagination span.current {
        background: #000;
        color: white;
        border-color: #000;
    }

    .pagination span.dots {
        border: none;
    }

    @media (max-width: 1024px) {
        .hero-container {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 36px;
        }

        .hero-buttons {
            flex-direction: column;
        }

        .hero-image {
            height: 300px;
        }

        .product-grid {
            grid-template-columns: 1fr;
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }
    }
</style>

<!-- HERO SECTION -->
<div class="hero-container">
    <div class="hero-content">
        <div class="hero-label">✓ TRENDING NOW</div>
        <h1 class="hero-title">THE NEXT WAVE OF AUTHENTICITY.</h1>
        <p class="hero-description">
            Access the world's most sought-after sneakers, apparel, and collectibles. Verified authentic, every time.
        </p>
        <div class="hero-buttons">
            <a href="/zapatillas?type=drops" class="btn-shop">SHOP DROPS</a>
            <a href="{% if app.user %}/vendedor/solicitar{% else %}{{ path('app_auth_login') }}{% endif %}" class="btn-sell">SELL NOW</a>
        </div>
    </div>
    <div class="hero-image">👟</div>
</div>

<!-- NEW RELEASES -->
<div class="section-header">
    <h2 class="section-title">NEW RELEASES</h2>
    <a href="/zapatillas" class="see-all">SEE ALL</a>
</div>
<p style="font-size: 13px; color: #666; margin-bottom: 20px;">The latest additions to the market.</p>

<div class="product-grid" id="new-releases">
    <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #999;">Cargando...</div>
</div>

<!-- PROMO SECTION -->
<div class="promo-section">
    <div class="promo-content">
        <div class="promo-subtitle">THE SELLERS HANDBOOK</div>
        <h2 class="promo-title">MAXIMIZE YOUR RETURN ON EVERY DROP</h2>
        <p class="promo-description">Learn insider strategies to grow your sneaker resale business</p>
        <a href="#" class="btn-promo">READ THE GUIDE</a>
    </div>
</div>

<!-- MOST POPULAR -->
<div class="section-header">
    <h2 class="section-title">MOST POPULAR</h2>
    <a href="/zapatillas?sort=popularity" class="see-all">SEE ALL</a>
</div>
<p style="font-size: 13px; color: #666; margin-bottom: 20px;">The highest volume trades of the last 24 hours.</p>

<div class="product-grid" id="most-popular">
    <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #999;">Cargando...</div>
</div>

<!-- UPCOMING DROPS -->
<div class="section-header">
    <h2 class="section-title">UPCOMING DROPS</h2>
    <a href="/zapatillas?sort=upcoming" class="see-all">CALENDAR</a>
</div>
<p style="font-size: 13px; color: #666; margin-bottom: 20px;">Set your alarms. These won't last long.</p>

<div class="product-grid" id="upcoming-drops" style="grid-template-columns: repeat(3, 1fr);">
    <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #999;">Cargando...</div>
</div>

<!-- PAGINATION EXAMPLE -->
<div class="pagination">
    <span class="current">1</span>
    <a href="#">2</a>
    <a href="#">3</a>
    <span class="dots">...</span>
    <a href="#">45</a>
    <a href="#">→</a>
</div>

<script>
    // Función para obtener URL de imagen basada en marca y modelo
    function getImageUrl(brand, model) {
        const brandLower = (brand || '').toLowerCase();
        const modelLower = (model || '').toLowerCase();
        
        const images = {
            'jordan': 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&h=500&fit=crop',
            'nike': 'https://images.unsplash.com/photo-1460353581641-694ee11ff7f5?w=500&h=500&fit=crop',
            'adidas': 'https://images.unsplash.com/photo-1556821552-5d6deb0c1819?w=500&h=500&fit=crop',
            'new balance': 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&h=500&fit=crop',
            'puma': 'https://images.unsplash.com/photo-1460353581641-694ee11ff7f5?w=500&h=500&fit=crop',
            'vans': 'https://images.unsplash.com/photo-1576209262819-45e6c88955ba?w=500&h=500&fit=crop',
            'converse': 'https://images.unsplash.com/photo-1576209262819-45e6c88955ba?w=500&h=500&fit=crop',
            'asics': 'https://images.unsplash.com/photo-1556821552-5d6deb0c1819?w=500&h=500&fit=crop',
            'hoka': 'https://images.unsplash.com/photo-1460353581641-694ee11ff7f5?w=500&h=500&fit=crop',
            'balenciaga': 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&h=500&fit=crop',
            'louis vuitton': 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&h=500&fit=crop',
        };
        
        for (let key in images) {
            if (brandLower.includes(key) || modelLower.includes(key)) {
                return images[key];
            }
        }
        
        return 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&h=500&fit=crop';
    }

    // Función para crear tarjeta de producto
    function createProductCard(shoe, showDate = false) {
        const card = document.createElement('a');
        card.href = `/zapatillas/${shoe.id}`;
        card.className = 'product-card';
        
        const imageUrl = getImageUrl(shoe.marca, shoe.modelo);
        const badge = shoe.is_new ? '<div class="product-badge">VERIFIED</div>' : '';
        const dateSection = showDate ? `<div class="product-category">OCT 24, 2024</div>` : '';
        
        card.innerHTML = `
            ${badge}
            <div class="product-image"><img src="${imageUrl}" alt="${shoe.modelo}" style="width:100%; height:100%; object-fit:cover;"></div>
            <div class="product-info">
                ${dateSection}
                <div class="product-category">${shoe.marca || 'NIKE'}</div>
                <div class="product-name">${shoe.modelo || 'Sneaker'}</div>
                <div class="product-price-container">
                    <div class="product-price">$${shoe.precio || '0'}</div>
                    <div class="product-change ${Math.random() > 0.5 ? '' : 'down'}">+12.4%</div>
                </div>
            </div>
            <button class="product-buy">BUY</button>
        `;
        return card;
    }

    // Cargar NEW RELEASES
    fetch('/api/zapatillas?limit=4&sort=latest')
        .then(res => res.json())
        .then(data => {
            const grid = document.getElementById('new-releases');
            grid.innerHTML = '';
            
            if (data.zapatillas && data.zapatillas.length > 0) {
                data.zapatillas.forEach(shoe => {
                    grid.appendChild(createProductCard(shoe));
                });
            } else {
                grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #999;">No hay zapatillas disponibles</div>';
            }
        })
        .catch(err => console.error('Error loading new releases:', err));

    // Cargar MOST POPULAR
    fetch('/api/zapatillas?limit=4&sort=popular')
        .then(res => res.json())
        .then(data => {
            const grid = document.getElementById('most-popular');
            grid.innerHTML = '';
            
            if (data.zapatillas && data.zapatillas.length > 0) {
                data.zapatillas.forEach(shoe => {
                    grid.appendChild(createProductCard(shoe));
                });
            }
        })
        .catch(err => console.error('Error loading popular:', err));

    // Cargar UPCOMING DROPS
    fetch('/api/zapatillas?limit=3&sort=upcoming')
        .then(res => res.json())
        .then(data => {
            const grid = document.getElementById('upcoming-drops');
            grid.innerHTML = '';
            
            if (data.zapatillas && data.zapatillas.length > 0) {
                data.zapatillas.forEach(shoe => {
                    grid.appendChild(createProductCard(shoe, true));
                });
            }
        })
        .catch(err => console.error('Error loading upcoming:', err));
</script>

{% endblock %}
