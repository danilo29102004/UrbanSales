{% extends "base.html.twig" %}

{% block title %}Dashboard - UrbanSole{% endblock %}

{% block body %}
<style>
    .dashboard-container {
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 30px;
    }

    .sidebar {
        background-color: #f5f5f5;
        padding: 20px;
        border-radius: 8px;
        height: fit-content;
    }

    .sidebar h3 {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 15px;
        text-transform: uppercase;
        color: #666;
    }

    .sidebar-menu {
        list-style: none;
    }

    .sidebar-menu li {
        margin-bottom: 10px;
    }

    .sidebar-menu a {
        display: block;
        padding: 10px 12px;
        text-decoration: none;
        color: #333;
        border-radius: 4px;
        transition: all 0.3s;
    }

    .sidebar-menu a:hover,
    .sidebar-menu a.active {
        background-color: #000;
        color: white;
    }

    .dashboard-content {
        background-color: #fff;
        padding: 30px;
        border-radius: 8px;
        border: 1px solid #e0e0e0;
    }

    .welcome-header {
        margin-bottom: 30px;
    }

    .welcome-header h1 {
        font-size: 28px;
        margin-bottom: 5px;
    }

    .welcome-header p {
        color: #666;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background-color: #f5f5f5;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
    }

    .stat-value {
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #666;
        font-size: 14px;
    }

    .section {
        margin-bottom: 30px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 15px;
        border-bottom: 2px solid #e0e0e0;
        padding-bottom: 10px;
    }

    .orders-table {
        width: 100%;
        border-collapse: collapse;
    }

    .orders-table th {
        background-color: #f5f5f5;
        padding: 12px;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid #e0e0e0;
    }

    .orders-table td {
        padding: 12px;
        border-bottom: 1px solid #e0e0e0;
    }

    .btn-action {
        display: inline-block;
        padding: 6px 12px;
        background-color: #000;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        font-size: 12px;
        transition: background-color 0.3s;
    }

    .btn-action:hover {
        background-color: #333;
    }

    @media (max-width: 768px) {
        .dashboard-container {
            grid-template-columns: 1fr;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-container">
    <div class="sidebar">
        <h3>Menú</h3>
        <ul class="sidebar-menu">
            <li><a href="/dashboard" class="active">Panel Principal</a></li>
            <li><a href="{{ path('app_mi_perfil') }}">Mi Perfil</a></li>
            <li><a href="/mis-ordenes">Mis Pedidos</a></li>
            <li><a href="/mis-favoritos">Mis Favoritos</a></li>
            {% if app.user.vendedor and app.user.vendedor.estado == 'APROBADO' %}
                <li><a href="{{ path('app_vendedor_panel') }}">Panel de Vendedor</a></li>
                <li><a href="{{ path('app_zapatilla_crear_formulario') }}">+ Nueva Zapatilla</a></li>
            {% elseif app.user.vendedor %}
                <li><a href="{{ path('app_vendedor_solicitar_formulario') }}">Estado Vendedor</a></li>
            {% else %}
                <li><a href="{{ path('app_vendedor_solicitar_formulario') }}">Vender Zapatillas</a></li>
            {% endif %}
            <li><a href="/soporte">Soporte</a></li>
        </ul>
    </div>

    <div class="dashboard-content">
        <div class="welcome-header">
            <h1>¡Bienvenido, {{ app.user.nombre }}!</h1>
            <p>Aquí está tu resumen de actividad en UrbanSole</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">0</div>
                <div class="stat-label">Pedidos Realizados</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">0</div>
                <div class="stat-label">Artículos en Carrito</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">0</div>
                <div class="stat-label">Favoritos Guardados</div>
            </div>
        </div>

        {% if app.user.vendedor %}
            <div class="section">
                <h2 class="section-title">📊 Estado de Vendedor</h2>
                <div style="padding: 15px; background-color: #f5f5f5; border-radius: 4px;">
                    <p><strong>Estado:</strong> <span class="badge 
                        {% if app.user.vendedor.estado == 'APROBADO' %}bg-success
                        {% elseif app.user.vendedor.estado == 'RECHAZADO' %}bg-danger
                        {% else %}bg-warning{% endif %}">
                        {{ app.user.vendedor.estado }}
                    </span></p>
                    {% if app.user.vendedor.estado == 'APROBADO' %}
                        <p style="color: #28a745;">✅ Tu cuenta de vendedor está aprobada. ¡Puedes comenzar a vender!</p>
                        <a href="{{ path('app_zapatilla_crear_formulario') }}" class="btn-action">Subir Nueva Zapatilla</a>
                        <a href="{{ path('app_vendedor_panel') }}" class="btn-action" style="margin-left: 10px;">Ver Panel</a>
                    {% elseif app.user.vendedor.estado == 'PENDIENTE' %}
                        <p style="color: #ff9800;">⏳ Tu solicitud está en revisión. Te notificaremos pronto.</p>
                    {% else %}
                        <p style="color: #d32f2f;">❌ Tu solicitud fue rechazada. Contacta con soporte.</p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="section">
                <h2 class="section-title">¿Quieres Vender en UrbanSole?</h2>
                <div style="padding: 15px; background-color: #f5f5f5; border-radius: 4px;">
                    <p>Solicita acceso a nuestro programa de vendedores y comienza a ganar dinero vendiendo tus zapatillas.</p>
                    <a href="{{ path('app_vendedor_solicitar_formulario') }}" class="btn-action" style="display: inline-block; margin-top: 10px;">Solicitar Acceso</a>
                </div>
            </div>
        {% endif %}

        <div class="section">
            <h2 class="section-title">Tus Últimos Pedidos</h2>
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>ID Pedido</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" style="text-align: center; color: #999;">No tienes pedidos aún</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="section">
            <h2 class="section-title">Atajos Rápidos</h2>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
                <a href="/zapatillas" class="btn-action" style="text-align: center; padding: 15px;">Explorar Zapatillas</a>
                <a href="/carrito" class="btn-action" style="text-align: center; padding: 15px;">Ver Carrito</a>
            </div>
        </div>
    </div>
</div>

{% endblock %}
