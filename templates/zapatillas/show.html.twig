{% extends "base.html.twig" %}

{% block title %}Product Detail - UrbanSole{% endblock %}

{% block body %}
<style>
    .product-detail-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .product-detail-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-bottom: 80px;
    }

    .product-gallery {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .gallery-image {
        background: #1a1a1a;
        height: 350px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 120px;
        border-radius: 0;
        cursor: pointer;
        position: relative;
    }

    .gallery-image:nth-child(1) {
        grid-column: 1/-1;
    }

    .gallery-image.active::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border: 3px solid #00ff00;
    }

    .product-info {
        display: flex;
        flex-direction: column;
    }

    .product-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #00ff00;
        color: #000;
        padding: 6px 12px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
        margin-bottom: 16px;
    }

    .product-brand {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #999;
        margin-bottom: 8px;
    }

    .product-title {
        font-size: 36px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: -0.5px;
    }

    .product-price {
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .product-price-change {
        font-size: 12px;
        color: #00ff00;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .price-history {
        background: #f5f5f5;
        padding: 16px;
        margin-bottom: 30px;
        border-radius: 0;
    }

    .price-history-title {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #999;
        margin-bottom: 12px;
    }

    .price-history-bars {
        display: flex;
        gap: 4px;
        height: 40px;
        align-items: flex-end;
    }

    .price-bar {
        flex: 1;
        background: #e5e5e5;
        border-radius: 0;
        position: relative;
    }

    .price-bar.last-sale {
        background: #00ff00;
    }

    .size-selector {
        margin-bottom: 30px;
    }

    .size-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .size-title-right {
        float: right;
        font-weight: 400;
        text-transform: none;
        letter-spacing: normal;
    }

    .size-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
    }

    .size-btn {
        padding: 12px;
        border: 1px solid #e5e5e5;
        background: white;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border-radius: 0;
    }

    .size-btn:hover {
        border-color: #000;
    }

    .size-btn.selected {
        background: #000;
        color: white;
        border-color: #000;
    }

    .product-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 30px;
    }

    .btn-buy {
        background: #000;
        color: white;
        padding: 16px;
        border: none;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-buy:hover {
        background: #333;
    }

    .btn-sell {
        background: white;
        color: #000;
        padding: 16px;
        border: 1px solid #000;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-sell:hover {
        background: #000;
        color: white;
    }

    .description {
        font-size: 13px;
        line-height: 1.6;
        color: #666;
        margin-bottom: 30px;
    }

    .description-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        color: #000;
    }

    .guarantee-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 16px;
        background: #f5f5f5;
        margin-bottom: 12px;
        border-radius: 0;
    }

    .guarantee-icon {
        font-size: 20px;
        flex-shrink: 0;
    }

    .guarantee-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .guarantee-title {
        font-weight: 700;
        font-size: 12px;
    }

    .guarantee-desc {
        font-size: 11px;
        color: #666;
    }

    /* PEOPLE ALSO VIEWED */
    .related-section {
        margin-top: 80px;
        padding-top: 60px;
        border-top: 1px solid #e5e5e5;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 30px;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .related-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 0;
        overflow: hidden;
        text-decoration: none;
        color: #000;
        transition: all 0.2s;
    }

    .related-card:hover {
        border-color: #000;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    .related-image {
        background: #f5f5f5;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
    }

    .related-info {
        padding: 16px;
    }

    .related-brand {
        font-size: 10px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .related-name {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .related-price {
        font-size: 14px;
        font-weight: 700;
    }

    @media (max-width: 1024px) {
        .product-detail-container {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .product-title {
            font-size: 24px;
        }

        .size-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .related-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="product-detail-wrapper">
    <div class="product-detail-container" id="productDetail">
        <div style="text-align: center; padding: 40px; color: #999;">Loading product...</div>
    </div>
</div>

<!-- PEOPLE ALSO VIEWED -->
<div class="product-detail-wrapper">
    <div class="related-section">
        <h2 class="section-title">PEOPLE ALSO VIEWED</h2>
        <div class="related-grid" id="relatedProducts">
            <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #999;">Loading related products...</div>
        </div>
    </div>
</div>

<script>
    // Get product ID from URL
    const productId = window.location.pathname.split('/').pop();

    async function loadProduct() {
        try {
            const response = await fetch(`/api/zapatillas/${productId}`);
            const data = await response.json();

            if (data.error) {
                document.getElementById('productDetail').innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 60px; color: #999;">Product not found</div>`;
                return;
            }

            const product = data.zapatilla;
            const selectedSize = '9';

            const html = `
                <div class="product-gallery">
                    <div class="gallery-image active" onclick="selectImage(this)">👟</div>
                    <div class="gallery-image" onclick="selectImage(this)">👟</div>
                    <div class="gallery-image" onclick="selectImage(this)">👟</div>
                    <div class="gallery-image" onclick="selectImage(this)">👟</div>
                </div>

                <div class="product-info">
                    <div class="product-badge">✓ VERIFIED AUTHENTIC</div>
                    <div class="product-brand">${product.marca || 'NIKE'}</div>
                    <h1 class="product-title">${product.modelo || 'SNEAKER'}<br>'VOLT'</h1>
                    
                    <div class="product-price">$${product.precio || '0'}</div>
                    <div class="product-price-change">+12.4%</div>

                    <div class="price-history">
                        <div class="price-history-title">PRICE HISTORY (30D)</div>
                        <div class="price-history-bars">
                            <div class="price-bar"></div>
                            <div class="price-bar"></div>
                            <div class="price-bar"></div>
                            <div class="price-bar"></div>
                            <div class="price-bar last-sale"></div>
                        </div>
                    </div>

                    <div class="size-selector">
                        <div class="size-title">
                            SELECT SIZE (US MEN)
                            <span class="size-title-right"><a href="#" style="color: #000; text-decoration: underline;">SIZE GUIDE</a></span>
                        </div>
                        <div class="size-grid">
                            <button class="size-btn" onclick="selectSize(this, 7)">7</button>
                            <button class="size-btn" onclick="selectSize(this, 8)">8</button>
                            <button class="size-btn" onclick="selectSize(this, 8.5)">8.5</button>
                            <button class="size-btn" onclick="selectSize(this, 9)" style="background: #000; color: white; border-color: #000;">9</button>
                            <button class="size-btn" onclick="selectSize(this, 9.5)">9.5</button>
                            <button class="size-btn" onclick="selectSize(this, 10)">10</button>
                            <button class="size-btn" onclick="selectSize(this, 11)">11</button>
                            <button class="size-btn" onclick="selectSize(this, 12)">12</button>
                        </div>
                    </div>

                    <div class="product-actions">
                        <button class="btn-buy" onclick="agregarAlCarrito(${product.id})">BUY NOW</button>
                        <button class="btn-sell">SELL FOR $${product.precio || '0'}</button>
                    </div>

                    <div class="description">
                        <div class="description-title">DESCRIPTION</div>
                        <p>The Nike x Off-White Air Force 1 'Volt' features a vibrant neon upper with signature Helvetica typography, exposed foam, and the iconic zip-tie accessory. A grail for any serious urban collector.</p>
                    </div>

                    <div>
                        <div class="guarantee-item">
                            <div class="guarantee-icon">🟢</div>
                            <div class="guarantee-text">
                                <div class="guarantee-title">Urban Sole Authenticity Guarantee</div>
                                <div class="guarantee-desc">Every item is physically inspected by our experts before shipping</div>
                            </div>
                        </div>

                        <div class="guarantee-item">
                            <div class="guarantee-icon">🚚</div>
                            <div class="guarantee-text">
                                <div class="guarantee-title">Express Global Shipping</div>
                                <div class="guarantee-desc">Estimated delivery: 3-5 business days. Single item London, UK.</div>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('productDetail').innerHTML = html;
            loadRelatedProducts();
        } catch (error) {
            console.error('Error:', error);
            document.getElementById('productDetail').innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 60px; color: #999;">Error loading product</div>`;
        }
    }

    async function loadRelatedProducts() {
        try {
            const response = await fetch('/api/zapatillas?limit=4');
            const data = await response.json();

            if (data.zapatillas && data.zapatillas.length > 0) {
                const html = data.zapatillas.slice(0, 4).map(product => `
                    <a href="/zapatillas/${product.id}" class="related-card">
                        <div class="related-image">👟</div>
                        <div class="related-info">
                            <div class="related-brand">${product.marca || 'NIKE'}</div>
                            <div class="related-name">${product.modelo || 'Sneaker'}</div>
                            <div class="related-price">$${product.precio || '0'}</div>
                        </div>
                    </a>
                `).join('');

                document.getElementById('relatedProducts').innerHTML = html;
            }
        } catch (error) {
            console.error('Error loading related:', error);
        }
    }

    function selectImage(el) {
        document.querySelectorAll('.gallery-image').forEach(img => img.classList.remove('active'));
        el.classList.add('active');
    }

    function selectSize(el, size) {
        document.querySelectorAll('.size-btn').forEach(btn => {
            btn.classList.remove('selected');
            btn.style.background = 'white';
            btn.style.color = '#000';
            btn.style.borderColor = '#e5e5e5';
        });
        el.classList.add('selected');
        el.style.background = '#000';
        el.style.color = 'white';
        el.style.borderColor = '#000';
    }

    async function agregarAlCarrito(productId) {
        if (!{{ app.user ? 'true' : 'false' }}) {
            window.location.href = '{{ path("app_auth_login") }}';
            return;
        }

        try {
            const response = await fetch('/api/carrito/agregar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    zapatilla_id: productId,
                    cantidad: 1
                })
            });

            if (response.ok) {
                // Update cart counter
                const carritoRes = await fetch('/api/carrito');
                const carritoData = await carritoRes.json();
                document.getElementById('cartCount').textContent = carritoData.cantidad_items || 0;
                
                alert('✅ Added to cart!');
                window.location.href = '/carrito';
            } else {
                alert('Error adding to cart');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error adding to cart');
        }
    }

    // Load product on page load
    loadProduct();
</script>

{% endblock %}
