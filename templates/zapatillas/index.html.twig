{% extends "base.html.twig" %}

{% block title %}Catálogo de Zapatillas - UrbanSole{% endblock %}

{% block body %}
<div class="container" style="max-width: 1400px; margin: 40px auto; padding: 0 20px;">
    <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 30px;">Catálogo de Zapatillas</h1>

    <div id="zapatillasContainer" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
        <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px;">
            <p style="font-size: 1.1rem; color: #666; margin-bottom: 20px;">Cargando zapatillas...</p>
            <div style="display: inline-block; width: 40px; height: 40px; border: 3px solid #e9e9e9; border-top-color: #000; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        </div>
    </div>
</div>

<style>
    @keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<script>
    async function cargarZapatillas() {
        try {
            const response = await fetch('/api/zapatillas');
            const data = await response.json();

            const container = document.getElementById('zapatillasContainer');
            container.innerHTML = '';

            if (!data.zapatillas || data.zapatillas.length === 0) {
                container.innerHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px;">
                        <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 10px;">No hay zapatillas disponibles</h2>
                        <p style="color: #666; margin-bottom: 20px;">Los vendedores aún no han subido sus productos</p>
                        <p style="color: #999;">Vuelve pronto para ver nuevas zapatillas</p>
                    </div>
                `;
                return;
            }

            data.zapatillas.forEach(zapatilla => {
                const card = document.createElement('div');
                card.innerHTML = `
                    <div style="background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); transition: transform 0.3s, box-shadow 0.3s; cursor: pointer;" onclick="window.location.href='/zapatillas/${zapatilla.id}'">
                        <div style="width: 100%; height: 250px; background: #e9e9e9; display: flex; align-items: center; justify-content: center; color: #999; font-weight: 600; overflow: hidden;">
                            ${zapatilla.imagen ? '<img src=\"' + zapatilla.imagen + '\" alt=\"' + zapatilla.modelo + '\" style=\"width: 100%; height: 100%; object-fit: cover;\">' : 'Sin imagen'}
                        </div>

                        <div style="padding: 16px;">
                            <h3 style="font-size: 1rem; font-weight: 700; margin-bottom: 8px; color: #000; min-height: 2.4em; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                ${zapatilla.modelo}
                            </h3>
                            <p style="font-size: 0.9rem; color: #666; margin-bottom: 8px;">${zapatilla.marca}</p>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; font-size: 0.9rem;">
                                <div>
                                    <span style="color: #999;">Talla:</span>
                                    <strong style="display: block; color: #000;">${zapatilla.talla}</strong>
                                </div>
                                <div>
                                    <span style="color: #999;">Precio:</span>
                                    <strong style="display: block; color: #000;">€${zapatilla.precio}</strong>
                                </div>
                            </div>

                            <div style="margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid #eee;">
                                <span style="color: #999; font-size: 0.9rem;">Stock:</span>
                                <strong style="display: block; color: #000; font-size: 1.1rem;">${zapatilla.stock} ${zapatilla.stock === 1 ? 'unidad' : 'unidades'}</strong>
                            </div>

                            <div style="display: flex; gap: 8px; align-items: center; justify-content: space-between;">
                                <span style="font-size: 0.85rem; color: #999; background: #f5f5f5; padding: 4px 8px; border-radius: 4px;">
                                    ${zapatilla.categoria}
                                </span>
                                <span style="font-size: 0.85rem; color: #999; background: #f5f5f5; padding: 4px 8px; border-radius: 4px;">
                                    Por: ${zapatilla.vendedor}
                                </span>
                            </div>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });

        } catch (error) {
            console.error('Error:', error);
            const container = document.getElementById('zapatillasContainer');
            container.innerHTML = `
                <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px;">
                    <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 10px; color: #d32f2f;">Error al cargar</h2>
                    <p style="color: #666;">No pudimos cargar el catálogo. Por favor, recarga la página.</p>
                </div>
            `;
        }
    }

    window.addEventListener('DOMContentLoaded', cargarZapatillas);
</script>

<style>
    .catalog-container {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 40px;
        margin-bottom: 60px;
    }

    .filters-sidebar {
        background: white;
        padding: 0;
        border-radius: 0;
        height: fit-content;
    }

    .filter-section {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #e5e5e5;
    }

    .filter-section:last-child {
        border-bottom: none;
    }

    .filter-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        color: #000;
    }

    .filter-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .filter-option {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-option input[type="checkbox"] {
        width: 16px;
        height: 16px;
        cursor: pointer;
        accent-color: #00ff00;
    }

    .filter-option label {
        margin: 0;
        cursor: pointer;
        font-size: 13px;
        color: #666;
