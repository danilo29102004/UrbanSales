{% extends "base.html.twig" %}

{% block title %}Registration Successful - UrbanSole{% endblock %}

{% block body %}
<style>
    .success-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 300px);
        padding: 40px 20px;
    }

    .success-card {
        background: #fff;
        padding: 60px 40px;
        text-align: center;
        max-width: 500px;
        border: 1px solid #e5e5e5;
    }

    .success-icon {
        font-size: 64px;
        margin-bottom: 30px;
        display: block;
    }

    .success-title {
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 20px;
        color: #000;
    }

    .success-message {
        font-size: 14px;
        color: #666;
        margin-bottom: 24px;
        line-height: 1.8;
        letter-spacing: 0.3px;
    }

    .email-highlight {
        background-color: #f5f5f5;
        padding: 16px;
        border: 1px solid #e5e5e5;
        margin: 24px 0;
        word-break: break-all;
        font-family: monospace;
        font-size: 13px;
        font-weight: 700;
        color: #00ff00;
    }

    .success-btn {
        display: inline-block;
        background-color: #000;
        color: white;
        padding: 14px 40px;
        border: none;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: background-color 0.3s;
        margin-top: 20px;
    }

    .success-btn:hover {
        background-color: #1a1a1a;
    }

    .success-steps {
        margin-top: 40px;
        padding-top: 40px;
        border-top: 1px solid #e5e5e5;
        text-align: left;
    }

    .success-step {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        font-size: 13px;
        line-height: 1.6;
        letter-spacing: 0.3px;
    }

    .success-step-number {
        min-width: 30px;
        height: 30px;
        background: #00ff00;
        color: #000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
    }

    .success-step-content {
        flex: 1;
    }

    .success-step-title {
        font-weight: 700;
        margin-bottom: 4px;
        color: #000;
    }

    .success-step-desc {
        color: #666;
    }
</style>

<div class="success-container">
    <div class="success-card">
        <span class="success-icon">✓</span>
        <h1 class="success-title">Welcome To<br>Urban Sole</h1>
        
        <p class="success-message">
            Your account has been successfully created! You now have full access to buy and sell verified authentic sneakers.
        </p>

        <div class="email-highlight">
            {{ usuario.email }}
        </div>

        <a href="{{ path('app_auth_login') }}" class="success-btn">
            Sign In To Get Started
        </a>

        <div class="success-steps">
            <div class="success-step">
                <div class="success-step-number">1</div>
                <div class="success-step-content">
                    <div class="success-step-title">Explore Our Catalog</div>
                    <div class="success-step-desc">Browse thousands of verified authentic sneakers on our marketplace.</div>
                </div>
            </div>

            <div class="success-step">
                <div class="success-step-number">2</div>
                <div class="success-step-content">
                    <div class="success-step-title">Make Your First Purchase</div>
                    <div class="success-step-desc">Add items to your cart and complete a secure checkout process.</div>
                </div>
            </div>

            <div class="success-step">
                <div class="success-step-number">3</div>
                <div class="success-step-content">
                    <div class="success-step-title">Start Selling</div>
                    <div class="success-step-desc">List your collection and earn money from every verified sale.</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
