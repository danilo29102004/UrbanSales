{% extends "base.html.twig" %}

{% block title %}Sign In - UrbanSole{% endblock %}

{% block body %}
<style>
    .auth-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 300px);
        padding: 40px 20px;
    }
    
    .auth-form-wrapper {
        width: 100%;
        max-width: 400px;
    }
    
    .auth-form-title {
        font-size: 32px;
        font-weight: 900;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
        color: #000;
    }
    
    .auth-form-subtitle {
        font-size: 14px;
        color: #666;
        margin-bottom: 40px;
        letter-spacing: 0.5px;
    }
    
    .auth-form-group {
        margin-bottom: 24px;
    }
    
    .auth-form-label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #000;
        margin-bottom: 8px;
    }
    
    .auth-form-input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #e5e5e5;
        border-radius: 0;
        font-family: inherit;
        font-size: 14px;
        background: #fff;
        color: #000;
        box-sizing: border-box;
        transition: border-color 0.3s ease;
    }
    
    .auth-form-input:focus {
        outline: none;
        border-color: #000;
    }
    
    .auth-form-input::placeholder {
        color: #999;
    }
    
    .auth-form-error {
        background: #ff4444;
        color: white;
        padding: 12px 16px;
        border-radius: 0;
        margin-bottom: 24px;
        font-size: 13px;
        letter-spacing: 0.5px;
    }
    
    .auth-checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 32px;
    }
    
    .auth-checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #00ff00;
    }
    
    .auth-checkbox-label {
        font-size: 13px;
        color: #666;
        cursor: pointer;
        margin: 0;
    }
    
    .auth-submit-btn {
        width: 100%;
        padding: 14px 0;
        background: #000;
        color: #fff;
        border: none;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .auth-submit-btn:hover {
        background: #1a1a1a;
    }
    
    .auth-form-footer {
        margin-top: 24px;
        text-align: center;
        font-size: 13px;
        color: #666;
        letter-spacing: 0.5px;
    }
    
    .auth-form-footer a {
        color: #00ff00;
        text-decoration: none;
        font-weight: 700;
    }
    
    .auth-form-footer a:hover {
        text-decoration: underline;
    }
    
    .auth-forgot-password {
        text-align: right;
        margin-top: 16px;
    }
    
    .auth-forgot-password a {
        font-size: 13px;
        color: #00ff00;
        text-decoration: none;
        font-weight: 700;
    }
    
    .auth-forgot-password a:hover {
        text-decoration: underline;
    }
</style>

<div class="auth-container">
    <div class="auth-form-wrapper">
        <h1 class="auth-form-title">Sign In</h1>
        <p class="auth-form-subtitle">Access your Urban Sole account</p>

        {% if error|default(false) %}
            <div class="auth-form-error">
                {{ error }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_auth_login') }}" data-turbo="false">
            <div class="auth-form-group">
                <label for="email" class="auth-form-label">Email</label>
                <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    class="auth-form-input"
                    required 
                    autofocus
                    value="{{ last_email ?? '' }}"
                    placeholder="your@email.com"
                >
            </div>

            <div class="auth-form-group">
                <label for="password" class="auth-form-label">Password</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    class="auth-form-input"
                    required
                    placeholder="••••••••"
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="auth-checkbox-group">
                <input 
                    type="checkbox" 
                    id="remember" 
                    name="_remember_me"
                    class="auth-checkbox"
                >
                <label for="remember" class="auth-checkbox-label">Remember me</label>
            </div>

            <button type="submit" class="auth-submit-btn">Sign In</button>
        </form>

        <div class="auth-forgot-password">
            <a href="#">Forgot password?</a>
        </div>

        <div class="auth-form-footer">
            Don't have an account? <a href="{{ path('app_auth_registro') }}">Create one</a>
        </div>
    </div>
</div>
{% endblock %}
