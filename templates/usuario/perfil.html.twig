{% extends "base.html.twig" %}

{% block title %}Mi Perfil - UrbanSole{% endblock %}

{% block body %}
<style>
    .perfil-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .perfil-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 30px;
        margin-top: 30px;
    }

    .perfil-sidebar {
        background: #f5f5f5;
        padding: 20px;
        border-radius: 8px;
        height: fit-content;
    }

    .perfil-card-user {
        text-align: center;
        padding-bottom: 20px;
        border-bottom: 1px solid #ddd;
        margin-bottom: 20px;
    }

    .perfil-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 900;
        margin: 0 auto 15px;
    }

    .perfil-content {
        background: #fff;
        padding: 30px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .perfil-menu {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .perfil-menu li {
        margin-bottom: 10px;
    }

    .perfil-menu a {
        display: block;
        padding: 12px;
        background: #e9e9e9;
        color: #000;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: center;
        transition: all 0.2s;
    }

    .perfil-menu a:hover {
        background: #000;
        color: #fff;
    }

    .perfil-menu a.active {
        background: #000;
        color: #fff;
    }

    .perfil-section {
        margin-bottom: 30px;
    }

    .perfil-section h3 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #000;
    }

    .perfil-field {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .perfil-item {
        display: flex;
        flex-direction: column;
    }

    .perfil-item label {
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: #333;
    }

    .perfil-item p {
        padding: 12px;
        background: #f5f5f5;
        border-radius: 4px;
        border: 1px solid #ddd;
        color: #666;
    }

    .alert {
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 4px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-warning {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .btn {
        display: inline-block;
        padding: 12px 24px;
        background: #000;
        color: #fff;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 1rem;
    }

    .btn:hover {
        background: #333;
    }

    .btn-secondary {
        background: #e9e9e9;
        color: #000;
    }

    .btn-secondary:hover {
        background: #ddd;
    }

    @media (max-width: 768px) {
        .perfil-grid {
            grid-template-columns: 1fr;
        }

        .perfil-field {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="perfil-container">
    <h1 style="font-size: 2.5rem; font-weight: 700;">Mi Perfil</h1>

    {% if app.flashes %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                {% set alertClass = (type == 'success') ? 'alert-success' : ((type == 'error') ? 'alert-danger' : 'alert-warning') %}
                <div class="alert {{ alertClass }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <div class="perfil-grid">
        <!-- SIDEBAR -->
        <div class="perfil-sidebar">
            <div class="perfil-card-user">
                <div class="perfil-avatar">
                    {{ usuario.nombre|first|upper }}
                </div>
                <h3 style="margin: 0; font-weight: 700;">
                    {{ usuario.nombre }}
                </h3>
                <p style="margin: 5px 0 0 0; color: #999; font-size: 0.9rem;">
                    {{ usuario.email }}
                </p>
                {% if vendedor %}
                    <div style="margin-top: 10px; padding: 8px 12px; background: #28a745; color: #fff; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">
                        ✓ Vendedor {{ vendedor.estado }}
                    </div>
                {% endif %}
            </div>

            <ul class="perfil-menu">
                <li><a href="{{ path('app_mi_perfil') }}" class="active">📋 Mi Perfil</a></li>
                <li><a href="{{ path('app_mi_perfil_editar') }}">✏️ Editar Perfil</a></li>
                {% if vendedor %}
                    <li><a href="{{ path('app_vendedor_zapatillas_listar') }}">👟 Mis Zapatillas</a></li>
                {% endif %}
                <li><a href="{{ path('app_auth_logout') }}">🚪 Cerrar Sesión</a></li>
            </ul>
        </div>

        <!-- CONTENIDO PRINCIPAL -->
        <div class="perfil-content">
            <!-- Información Personal -->
            <div class="perfil-section">
                <h3>Información Personal</h3>

                <div class="perfil-field">
                    <div class="perfil-item">
                        <label>Nombre Completo</label>
                        <p>{{ usuario.nombre }}</p>
                    </div>
                    <div class="perfil-item">
                        <label>Email</label>
                        <p>{{ usuario.email }}</p>
                    </div>
                </div>

                <div style="margin-top: 20px;">
                    <a href="{{ path('app_mi_perfil_editar') }}" class="btn btn-secondary">Editar Información</a>
                </div>
            </div>

            <!-- Información de Vendedor -->
            {% if vendedor %}
                <div class="perfil-section">
                    <h3>Información de Vendedor</h3>

                    {% set estadoBg = (vendedor.estado == 'APROBADO') ? 'alert-success' : ((vendedor.estado == 'RECHAZADO') ? 'alert-danger' : 'alert-warning') %}
                    <div class="alert {{ estadoBg }}" style="margin-bottom: 20px;">
                        <strong>Estado: {{ vendedor.estado }}</strong>
                    </div>

                    <div class="perfil-field">
                        <div class="perfil-item">
                            <label>DNI</label>
                            <p>{{ vendedor.dni }}</p>
                        </div>
                        <div class="perfil-item">
                            <label>Estado</label>
                            <p>{{ vendedor.estado }}</p>
                        </div>
                    </div>

                    <div class="perfil-field">
                        <div class="perfil-item">
                            <label>Fecha de Solicitud</label>
                            <p>{{ vendedor.fechaSolicitud|date('d/m/Y H:i') }}</p>
                        </div>
                        {% if vendedor.fechaAprobacion %}
                            <div class="perfil-item">
                                <label>Fecha de Aprobación</label>
                                <p>{{ vendedor.fechaAprobacion|date('d/m/Y H:i') }}</p>
                            </div>
                        {% endif %}
                    </div>

                    {% if vendedor.estado == 'APROBADO' %}
                        <div style="margin-top: 20px;">
                            <a href="{{ path('app_vendedor_zapatillas_listar') }}" class="btn">Ver Mis Zapatillas</a>
                            <a href="{{ path('app_vendedor_zapatillas_crear') }}" class="btn" style="margin-left: 10px;">➕ Subir Nueva Zapatilla</a>
                        </div>
                    {% elseif vendedor.estado == 'PENDIENTE' %}
                        <div class="alert alert-warning" style="margin-top: 20px;">
                            Tu solicitud está siendo revisada. Te notificaremos cuando sea aprobada.
                        </div>
                    {% else %}
                        <div class="alert alert-danger" style="margin-top: 20px;">
                            Tu solicitud fue rechazada. Contacta con soporte para más información.
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="perfil-section">
                    <h3>Conviértete en Vendedor</h3>

                    <p style="margin-bottom: 20px; color: #666;">
                        ¿Quieres vender tus zapatillas? Solicita acceso como vendedor y comienza a ganar dinero.
                    </p>

                    <a href="{{ path('app_vendedor_solicitar_formulario') }}" class="btn">Solicitar Acceso de Vendedor</a>
                </div>
            {% endif %}

            <!-- Acciones Rápidas -->
            <div class="perfil-section" style="margin-top: 40px; padding-top: 20px; border-top: 2px solid #ddd;">
                <h3 style="border: none; margin-bottom: 20px;">Acciones Rápidas</h3>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                    <a href="{{ path('app_zapatillas_list') }}" class="btn btn-secondary">🛍️ Ver Catálogo</a>
                    <a href="{{ path('app_carrito') }}" class="btn btn-secondary">🛒 Mi Carrito</a>
                    <a href="{{ path('app_mi_perfil_editar') }}" class="btn btn-secondary">🔒 Cambiar Contraseña</a>
                    <a href="{{ path('app_home') }}" class="btn btn-secondary">🏠 Ir al Inicio</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
