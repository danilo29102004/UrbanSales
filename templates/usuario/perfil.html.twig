{% extends "base.html.twig" %}

{% block title %}My Profile - UrbanSole{% endblock %}

{% block body %}
<style>
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 1px solid #e5e5e5;
    }

    .profile-title {
        font-size: 32px;
        font-weight: 900;
        text-transform: uppercase;
    }

    .profile-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 40px;
        margin-bottom: 60px;
    }

    .profile-sidebar {
        background: #fff;
        border: 1px solid #e5e5e5;
        padding: 0;
        height: fit-content;
        position: sticky;
        top: 100px;
    }

    .profile-user-card {
        padding: 20px;
        border-bottom: 1px solid #e5e5e5;
        text-align: center;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #00ff00 0%, #000 100%);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 900;
        margin: 0 auto 15px;
    }

    .profile-name {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .profile-email {
        font-size: 11px;
        color: #999;
        word-break: break-all;
    }

    .profile-menu {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .profile-menu-item {
        padding: 14px 20px;
        border-bottom: 1px solid #e5e5e5;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.2s;
        color: #666;
    }

    .profile-menu-item:last-child {
        border-bottom: none;
    }

    .profile-menu-item:hover {
        background: #f5f5f5;
        color: #000;
    }

    .profile-menu-item.active {
        background: #000;
        color: #00ff00;
        border-left: 3px solid #00ff00;
        padding-left: 17px;
    }

    .profile-content {
        background: #fff;
        border: 1px solid #e5e5e5;
        padding: 30px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e5e5e5;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #000;
    }

    .form-value {
        font-size: 13px;
        color: #666;
        padding: 10px;
        background: #f5f5f5;
        border: 1px solid #e5e5e5;
    }

    .vendor-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 0;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .vendor-badge.approved {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .vendor-badge.pending {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .vendor-badge.rejected {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }

    .empty-state p {
        font-size: 14px;
        margin-bottom: 20px;
    }

    .btn-action {
        display: inline-block;
        padding: 10px 20px;
        background: #000;
        color: #fff;
        text-decoration: none;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.2s;
    }

    .btn-action:hover {
        background: #00ff00;
        color: #000;
    }

    .tab-content {
        display: none;
    }

    .tab-content.active {
        display: block;
    }

    @media (max-width: 768px) {
        .profile-container {
            grid-template-columns: 1fr;
        }

        .profile-sidebar {
            position: relative;
            top: 0;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

{% if not app.user %}
<div style="text-align: center; padding: 80px 20px;">
    <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 10px;">Sign In Required</h2>
    <p style="color: #666; margin-bottom: 30px; font-size: 14px;">Sign in to view your profile and orders</p>
    <a href="/auth/login" class="btn-action">Sign In</a>
</div>
{% else %}

<div style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
    <div class="profile-header">
        <h1 class="profile-title">MY ACCOUNT</h1>
    </div>

    <div class="profile-container">
        <!-- SIDEBAR -->
        <div class="profile-sidebar">
            <div class="profile-user-card">
                <div class="profile-avatar">{{ app.user.nombre|first|upper }}</div>
                <div class="profile-name">{{ app.user.nombre }}</div>
                <div class="profile-email">{{ app.user.email }}</div>
            </div>

            <ul class="profile-menu">
                <li class="profile-menu-item active" onclick="switchTab(event, 'info')">📋 INFORMATION</li>
                <li class="profile-menu-item" onclick="switchTab(event, 'orders')">📦 ORDERS</li>
                <li class="profile-menu-item" onclick="switchTab(event, 'vendor')">💼 SELLER</li>
            </ul>
        </div>

        <!-- CONTENT -->
        <div class="profile-content">
            <!-- INFORMATION TAB -->
            <div id="info" class="tab-content active">
                <h2 class="section-title">Personal Information</h2>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">FULL NAME</label>
                        <div class="form-value">{{ app.user.nombre }}</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">EMAIL</label>
                        <div class="form-value">{{ app.user.email }}</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">ACCOUNT STATUS</label>
                        <div class="form-value">✅ VERIFIED</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">MEMBER SINCE</label>
                        <div class="form-value">2024</div>
                    </div>
                </div>
            </div>

            <!-- ORDERS TAB -->
            <div id="orders" class="tab-content">
                <h2 class="section-title">My Orders</h2>
                
                <div class="empty-state">
                    <p>No orders yet</p>
                    <a href="/zapatillas" class="btn-action">START SHOPPING</a>
                </div>
            </div>

            <!-- VENDOR TAB -->
            <div id="vendor" class="tab-content">
                <h2 class="section-title">Seller Status</h2>
                
                {% if app.user.vendedor %}
                    {% if app.user.vendedor.estado == 'APROBADO' %}
                        <div style="background: #d4edda; border: 1px solid #c3e6cb; padding: 20px; margin-bottom: 20px;">
                            <p style="color: #155724; font-weight: 700; margin-bottom: 10px;">✅ APPROVED SELLER</p>
                            <p style="color: #155724; font-size: 13px; margin-bottom: 15px;">You can upload sneakers to your catalog and start earning.</p>
                            <a href="/zapatillas/crear" class="btn-action">UPLOAD NEW SNEAKER</a>
                        </div>
                    {% elseif app.user.vendedor.estado == 'PENDIENTE' %}
                        <div style="background: #fff3cd; border: 1px solid #ffeeba; padding: 20px; margin-bottom: 20px;">
                            <p style="color: #856404; font-weight: 700; margin-bottom: 10px;">⏳ PENDING REVIEW</p>
                            <p style="color: #856404; font-size: 13px;">Your seller request is under review. Check your email for updates.</p>
                        </div>
                    {% else %}
                        <div style="background: #f8d7da; border: 1px solid #f5c6cb; padding: 20px; margin-bottom: 20px;">
                            <p style="color: #721c24; font-weight: 700; margin-bottom: 10px;">❌ APPLICATION REJECTED</p>
                            <p style="color: #721c24; font-size: 13px;">Contact support for more information.</p>
                        </div>
                    {% endif %}
                {% else %}
                    <div class="empty-state">
                        <p>Not a seller yet?</p>
                        <a href="/vendedor/solicitar" class="btn-action">BECOME A SELLER</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
function switchTab(event, tabName) {
    event.preventDefault();
    
    // Hide all tabs
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
    });

    // Deactivate all menu items
    document.querySelectorAll('.profile-menu-item').forEach(item => {
        item.classList.remove('active');
    });

    // Show selected tab
    document.getElementById(tabName).classList.add('active');
    event.target.classList.add('active');
}
</script>

{% endif %}

{% endblock %}
