{% extends 'base.html.twig' %}

{% block title %}Editar Perfil - UrbanSole{% endblock %}

{% block content %}
<div class="container" style="max-width: 700px; margin: 40px auto; padding: 0 20px;">
    <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 30px;">Editar Perfil</h1>

    {% if app.flashes %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                {% set bgColor = (type == 'success') ? '#d4edda' : ((type == 'error') ? '#f8d7da' : '#d1ecf1') %}
                {% set textColor = (type == 'success') ? '#155724' : ((type == 'error') ? '#721c24' : '#0c5460') %}
                <div style="padding: 15px; margin-bottom: 20px; border-radius: 4px; background: {{ bgColor }}; color: {{ textColor }};">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <form method="POST" action="{{ path('app_mi_perfil_actualizar') }}" style="background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_profile') }}">
        
        <!-- Nombre -->
        <div style="margin-bottom: 24px;">
            <label for="nombre" style="display: block; margin-bottom: 8px; font-weight: 600;">Nombre Completo</label>
            <input type="text" id="nombre" name="nombre" value="{{ usuario.nombre }}" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
        </div>

        <!-- Email -->
        <div style="margin-bottom: 24px;">
            <label for="email" style="display: block; margin-bottom: 8px; font-weight: 600;">Email</label>
            <input type="email" id="email" name="email" value="{{ usuario.email }}" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
            <small style="color: #999; font-size: 0.9rem; margin-top: 5px; display: block;">Si cambias el email, tendrás que verificarlo</small>
        </div>

        <div style="padding: 20px; background: #f5f5f5; border-radius: 8px; margin-bottom: 24px; border-left: 4px solid #ffc107;">
            <h3 style="font-weight: 700; margin-bottom: 15px; margin-top: 0;">Cambiar Contraseña (Opcional)</h3>
            <p style="color: #666; margin: 0;">Deja estos campos vacíos si no deseas cambiar tu contraseña</p>
        </div>

        <!-- Contraseña Actual -->
        <div style="margin-bottom: 24px;">
            <label for="password_actual" style="display: block; margin-bottom: 8px; font-weight: 600;">Contraseña Actual</label>
            <input type="password" id="password_actual" name="password_actual" placeholder="Ingresa tu contraseña actual" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
            <small style="color: #999; font-size: 0.9rem; margin-top: 5px; display: block;">Requerida si quieres cambiar tu contraseña</small>
        </div>

        <!-- Nueva Contraseña -->
        <div style="margin-bottom: 24px;">
            <label for="password_nueva" style="display: block; margin-bottom: 8px; font-weight: 600;">Nueva Contraseña</label>
            <input type="password" id="password_nueva" name="password_nueva" placeholder="Ingresa tu nueva contraseña" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
            <small style="color: #999; font-size: 0.9rem; margin-top: 5px; display: block;">Mínimo 6 caracteres</small>
        </div>

        <!-- Botones -->
        <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <a href="{{ path('app_mi_perfil') }}" style="padding: 12px 24px; background: #e9e9e9; color: #000; border-radius: 4px; text-decoration: none; font-weight: 600; cursor: pointer;">Cancelar</a>
            <button type="submit" style="padding: 12px 24px; background: #000; color: #fff; border: none; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 1rem;">Guardar Cambios</button>
        </div>
    </form>
</div>
{% endblock %}
