{% extends 'base.html.twig' %}

{% block title %}Solicitar Ser Vendedor - UrbanSole{% endblock %}

{% block body %}
<div class="container">
    <div class="form-card">
        <h1 class="form-title">
            {% if vendedor %}
                Mi Solicitud de Vendedor
            {% else %}
                Convertirse en Vendedor
            {% endif %}
        </h1>

        {% if vendedor %}
            <!-- Mostrar estado de solicitud existente -->
            <div class="form-success" style="background-color: #f0f0f0; padding: 20px; border-radius: 8px; border-left: 4px solid #007bff; margin-bottom: 20px;">
                <h3 style="margin-top: 0; color: #333;">Estado de tu solicitud</h3>
                
                <div style="margin: 15px 0;">
                    <strong style="color: #666;">Estado:</strong>
                    <span style="
                        display: inline-block;
                        padding: 8px 12px;
                        border-radius: 20px;
                        font-weight: bold;
                        margin-left: 10px;
                        {% if vendedor.estado == 'APROBADO' %}
                            background-color: #d4edda;
                            color: #155724;
                        {% elseif vendedor.estado == 'RECHAZADO' %}
                            background-color: #f8d7da;
                            color: #721c24;
                        {% else %}
                            background-color: #fff3cd;
                            color: #856404;
                        {% endif %}
                    ">
                        {{ vendedor.estado }}
                    </span>
                </div>

                <div style="margin: 10px 0; color: #666;">
                    <strong>Fecha de solicitud:</strong> {{ vendedor.fechaSolicitud.format('d/m/Y H:i') }}
                </div>

                {% if vendedor.fechaAprobacion %}
                    <div style="margin: 10px 0; color: #666;">
                        <strong>Fecha de aprobación:</strong> {{ vendedor.fechaAprobacion.format('d/m/Y H:i') }}
                    </div>
                {% endif %}
            </div>

            {% if vendedor.estado == 'APROBADO' %}
                <div class="form-success" style="background-color: #d4edda; padding: 15px; border-radius: 8px; border-left: 4px solid #28a745; margin-bottom: 20px;">
                    <strong style="color: #155724;">✅ ¡Felicitaciones! Tu solicitud ha sido aprobada.</strong>
                    <p style="margin: 10px 0 0 0; color: #155724;">Ahora puedes subir zapatillas a nuestro catálogo.</p>
                </div>
                <div style="display: flex; gap: 10px;">
                    <a href="{{ path('app_vendedor_panel') }}" class="btn-submit" style="text-decoration: none; text-align: center;">Mi Panel de Vendedor</a>
                    <a href="{{ path('app_zapatilla_crear_formulario') }}" class="btn-submit" style="text-decoration: none; text-align: center; background-color: #28a745;">Subir Zapatillas</a>
                </div>
            {% elseif vendedor.estado == 'RECHAZADO' %}
                <div class="form-error" style="background-color: #f8d7da; padding: 15px; border-radius: 8px; border-left: 4px solid #dc3545;">
                    <strong style="color: #721c24;">❌ Tu solicitud ha sido rechazada.</strong>
                    <p style="margin: 10px 0 0 0; color: #721c24;">Por favor contacta con el equipo de soporte para más información.</p>
                </div>
            {% else %}
                <div class="form-error" style="background-color: #fff3cd; padding: 15px; border-radius: 8px; border-left: 4px solid #ffc107;">
                    <strong style="color: #856404;">⏳ Tu solicitud está siendo revisada.</strong>
                    <p style="margin: 10px 0 0 0; color: #856404;">Por favor espera la confirmación. Esta suele tomar 1-2 días hábiles.</p>
                </div>
            {% endif %}

        {% else %}
            <!-- Mostrar formulario para solicitar acceso como vendedor -->
            <p style="color: #666; margin-bottom: 25px; line-height: 1.6;">
                Para convertirte en vendedor en UrbanSole, necesitas rellenar <strong>TODOS los campos</strong> con tus documentos de verificación.
                <br><br>
                <strong>Asegúrate de que:</strong>
            </p>

            <div style="background-color: #f9f9f9; padding: 15px; border-radius: 8px; margin-bottom: 25px; border-left: 4px solid #ff6b6b;">
                <ul style="margin: 0; padding-left: 20px;">
                    <li style="margin: 8px 0; color: #333;"><strong>Tu DNI/Cédula es válido y legible</strong></li>
                    <li style="margin: 8px 0; color: #333;"><strong>El documento de verificación es en formato PDF, JPG o PNG</strong></li>
                    <li style="margin: 8px 0; color: #333;"><strong>Incluyes tanto el frente como el dorso (si aplica)</strong></li>
                    <li style="margin: 8px 0; color: #333;"><strong>Tu información es correcta y completa</strong></li>
                </ul>
            </div>

            <form id="solicitudForm" enctype="multipart/form-data" data-turbo="false">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('app_vendedor_solicitar') }}">

                <div class="form-group">
                    <label for="dni">DNI/Cédula de Identidad <span style="color: #ff6b6b; font-weight: bold;">*</span></label>
                    <input 
                        type="text" 
                        id="dni" 
                        name="dni" 
                        required 
                        autofocus
                        placeholder="Ej: 12345678-A o 12345678"
                        style="font-size: 16px;"
                    >
                    <small style="display: block; color: #999; margin-top: 5px;">
                        Número de identificación (obligatorio)
                    </small>
                </div>

                <div class="form-group">
                    <label for="documento">Documento de Verificación <span style="color: #ff6b6b; font-weight: bold;">*</span></label>
                    <input 
                        type="file" 
                        id="documento" 
                        name="documento" 
                        accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                        required
                        style="padding: 12px; border: 2px dashed #ccc; border-radius: 6px; width: 100%; box-sizing: border-box; cursor: pointer; font-size: 14px;"
                    >
                    <small style="display: block; color: #999; margin-top: 5px;">
                        Sube tu DNI/Cédula (frente y dorso), comprobante de domicilio, o documento de identificación
                    </small>
                </div>

                <div style="background-color: #e8f4f8; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #0099cc;">
                    <strong style="color: #0099cc;">📄 Documentos aceptados:</strong>
                    <ul style="margin: 10px 0 0 0; padding-left: 20px;">
                        <li style="color: #333; margin: 5px 0;">📷 Fotocopia del DNI/Cédula (frente y dorso)</li>
                        <li style="color: #333; margin: 5px 0;">📋 Comprobante de domicilio reciente</li>
                        <li style="color: #333; margin: 5px 0;">💳 Datos de cuenta bancaria (opcional)</li>
                    </ul>
                </div>

                <button type="submit" class="btn-submit" style="width: 100%; font-size: 16px; padding: 12px;">
                    📤 Enviar Solicitud
                </button>
            </form>

            <div id="mensajeError" class="form-error" style="display: none; margin-top: 15px;"></div>
            <div id="mensajeExito" class="form-success" style="display: none; margin-top: 15px;"></div>
        {% endif %}
    </div>
</div>

<style>
    #documento::-webkit-file-upload-button {
        background-color: #007bff;
        color: white;
        padding: 8px 16px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        font-weight: bold;
    }

    #documento::-webkit-file-upload-button:hover {
        background-color: #0056b3;
    }
</style>

<script>
document.getElementById('solicitudForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Limpiar mensajes previos
    document.getElementById('mensajeError').style.display = 'none';
    document.getElementById('mensajeExito').style.display = 'none';
    
    const dni = document.getElementById('dni').value.trim();
    const documento = document.getElementById('documento').files[0];
    const submitBtn = e.target.querySelector('button[type="submit"]');
    
    // Validar que todos los campos estén rellenos
    if (!dni || !documento) {
        const errorDiv = document.getElementById('mensajeError');
        errorDiv.innerHTML = '❌ Debes rellenar TODOS los campos (DNI y Documento)';
        errorDiv.style.display = 'block';
        return;
    }

    submitBtn.disabled = true;
    submitBtn.innerHTML = '⏳ Enviando...';

    try {
        const formData = new FormData(e.target);
        
        const response = await fetch('{{ path("app_vendedor_solicitar") }}', {
            method: 'POST',
            body: formData
        });

        const data = await response.json();

        if (response.ok) {
            const successDiv = document.getElementById('mensajeExito');
            successDiv.innerHTML = '✅ ' + data.mensaje;
            successDiv.style.display = 'block';
            e.target.reset();
            
            setTimeout(() => location.reload(), 2000);
        } else {
            const errorDiv = document.getElementById('mensajeError');
            errorDiv.innerHTML = '❌ ' + (data.error || 'Error al enviar la solicitud');
            errorDiv.style.display = 'block';
        }
    } catch (error) {
        const errorDiv = document.getElementById('mensajeError');
        errorDiv.innerHTML = '❌ Error: ' + error.message;
        errorDiv.style.display = 'block';
    } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '📤 Enviar Solicitud';
    }
});
</script>
{% endblock %}
