{% extends "base.html.twig" %}

{% block title %}Checkout - UrbanSole{% endblock %}

{% block body %}
<style>
    .checkout-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .checkout-steps {
        display: flex;
        gap: 40px;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 1px solid #e5e5e5;
    }

    .step {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #999;
        position: relative;
        padding-bottom: 0;
    }

    .step.active {
        color: #000;
    }

    .step::after {
        content: '';
        position: absolute;
        bottom: -21px;
        left: 0;
        right: 0;
        height: 2px;
        background: #000;
        opacity: 0;
    }

    .step.active::after {
        opacity: 1;
    }

    .checkout-container {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 40px;
        margin-bottom: 60px;
    }

    .checkout-form {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 0;
        padding: 0;
    }

    .form-section {
        padding: 30px;
        border-bottom: 1px solid #e5e5e5;
    }

    .form-section:last-child {
        border-bottom: none;
    }

    .form-title {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 25px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-row.full {
        grid-template-columns: 1fr;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-group label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #000;
    }

    .form-group input,
    .form-group select {
        padding: 10px;
        border: 1px solid #e5e5e5;
        background: white;
        font-size: 13px;
        font-family: inherit;
        border-radius: 0;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #000;
        box-shadow: none;
    }

    .security-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        color: #00ff00;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e5e5e5;
    }

    .btn-next {
        width: 100%;
        padding: 14px;
        background: #000;
        color: white;
        border: none;
        border-radius: 0;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        margin-top: 20px;
        transition: all 0.2s;
    }

    .btn-next:hover {
        background: #333;
    }

    .order-summary {
        background: white;
        border: 1px solid #e5e5e5;
        padding: 20px;
        border-radius: 0;
        height: fit-content;
        position: sticky;
        top: 100px;
    }

    .summary-title {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e5e5e5;
    }

    .product-item {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 1px solid #e5e5e5;
    }

    .product-image {
        width: 80px;
        height: 80px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        flex-shrink: 0;
    }

    .product-info {
        flex: 1;
    }

    .product-name {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .product-specs {
        font-size: 10px;
        color: #999;
        margin-bottom: 8px;
    }

    .product-price {
        font-size: 13px;
        font-weight: 700;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 12px;
    }

    .summary-row.total {
        border-top: 1px solid #e5e5e5;
        padding-top: 15px;
        margin-top: 15px;
        font-size: 14px;
        font-weight: 700;
    }

    .guarantee {
        background: #f5f5f5;
        border-left: 3px solid #00ff00;
        padding: 12px;
        margin-top: 16px;
        font-size: 10px;
        line-height: 1.5;
    }

    .guarantee-title {
        font-weight: 700;
        margin-bottom: 4px;
    }

    @media (max-width: 768px) {
        .checkout-container {
            grid-template-columns: 1fr;
        }

        .order-summary {
            position: relative;
            top: 0;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="checkout-wrapper">
    <!-- STEPS INDICATOR -->
    <div class="checkout-steps">
        <div class="step active">01 SHIPPING</div>
        <div class="step">02 PAYMENT</div>
        <div class="step">03 REVIEW</div>
    </div>

    <!-- CHECKOUT CONTENT -->
    <div class="checkout-container">
        <!-- CHECKOUT FORM -->
        <div class="checkout-form" id="checkoutForm">
            <!-- SHIPPING INFORMATION -->
            <div class="form-section">
                <h3 class="form-title">SHIPPING INFORMATION</h3>
                <p style="font-size: 12px; color: #666; margin-bottom: 25px;">Enter your delivery details to proceed with the transaction.</p>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>FIRST NAME</label>
                        <input type="text" id="firstName" placeholder="Alex" required>
                    </div>
                    <div class="form-group">
                        <label>LAST NAME</label>
                        <input type="text" id="lastName" placeholder="Jordan" required>
                    </div>
                </div>

                <div class="form-row full">
                    <div class="form-group">
                        <label>STREET ADDRESS</label>
                        <input type="text" id="address" placeholder="742 Evergreen Terrace" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>CITY</label>
                        <input type="text" id="city" placeholder="Springfield" required>
                    </div>
                    <div class="form-group">
                        <label>STATE</label>
                        <input type="text" id="state" placeholder="IL" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>ZIP</label>
                        <input type="text" id="zip" placeholder="62704" required>
                    </div>
                    <div class="form-group">
                        <label>PHONE NUMBER</label>
                        <input type="tel" id="phone" placeholder="+1 (555) 000-0000" required>
                    </div>
                </div>

                <div class="security-badge">
                    ✓ SECURE END-TO-END ENCRYPTION
                </div>
            </div>

            <div class="form-section" style="padding: 30px;">
                <button class="btn-next" onclick="irAlPago()">CONTINUE TO PAYMENT →</button>
            </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="order-summary">
            <div class="summary-title">ORDER SUMMARY</div>

            <div class="product-item" id="productSummary">
                <div class="product-image">👟</div>
                <div class="product-info">
                    <div class="product-name">VAPOR MAX ELITE</div>
                    <div class="product-specs">SIZE: 10.5 US | RED/BLACK</div>
                    <div class="product-price">$240.00</div>
                </div>
            </div>

            <div class="summary-row">
                <span>SUBTOTAL</span>
                <span id="subtotal">$240.00</span>
            </div>

            <div class="summary-row">
                <span>SHIPPING</span>
                <span id="shipping">$15.00</span>
            </div>

            <div class="summary-row">
                <span>AUTHENTICATION</span>
                <span id="auth">FREE</span>
            </div>

            <div class="summary-row total">
                <span>TOTAL</span>
                <span id="total">$255.00</span>
            </div>

            <div class="guarantee" style="border-left-color: #00ff00;">
                <div class="guarantee-title">🟢 SOLE VERIFIED</div>
                <div>Guaranteed authentic by Urban Sole experts.</div>
            </div>

            <div class="guarantee" style="border-left-color: #000;">
                <div class="guarantee-title">🚚 EXPRESS GLOBAL SHIPPING</div>
                <div>Estimated delivery: 3-5 business days. Single item London, UK.</div>
            </div>
        </div>
    </div>
</div>

<script>
async function irAlPago() {
    const firstName = document.getElementById('firstName').value.trim();
    const lastName = document.getElementById('lastName').value.trim();
    const address = document.getElementById('address').value.trim();
    const city = document.getElementById('city').value.trim();
    const state = document.getElementById('state').value.trim();
    const zip = document.getElementById('zip').value.trim();
    const phone = document.getElementById('phone').value.trim();

    if (!firstName || !lastName || !address || !city || !state || !zip || !phone) {
        alert('Please fill in all fields');
        return;
    }

    try {
        const response = await fetch('/api/pedido/crear', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                nombre: firstName + ' ' + lastName,
                email: '{{ app.user.email }}',
                telefono: phone,
                direccion: address,
                ciudad: city,
                estado: state,
                codigo_postal: zip,
                metodo_pago: 'credit_card'
            })
        });

        if (response.ok) {
            const data = await response.json();
            window.location.href = '/pedido/' + data.id + '/confirmacion';
        } else {
            const error = await response.json();
            alert('Error: ' + (error.error || 'Could not create order'));
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error creating order');
    }
}

// Cargar datos del carrito en el resumen
async function cargarResumen() {
    try {
        const response = await fetch('/api/carrito');
        const data = await response.json();
        
        if (data.detalles && data.detalles.length > 0) {
            const item = data.detalles[0];
            const subtotal = item.zapatilla.precio * item.cantidad;
            const shipping = 15;
            const total = subtotal + shipping;

            document.getElementById('productSummary').innerHTML = `
                <div class="product-image">👟</div>
                <div class="product-info">
                    <div class="product-name">${item.zapatilla.modelo.toUpperCase()}</div>
                    <div class="product-specs">SIZE: 10.5 US | QTY: ${item.cantidad}</div>
                    <div class="product-price">$${(item.zapatilla.precio).toFixed(2)}</div>
                </div>
            `;

            document.getElementById('subtotal').textContent = '$' + subtotal.toFixed(2);
            document.getElementById('shipping').textContent = '$' + shipping.toFixed(2);
            document.getElementById('total').textContent = '$' + total.toFixed(2);
        }
    } catch (error) {
        console.error('Error loading cart:', error);
    }
}

cargarResumen();
</script>

